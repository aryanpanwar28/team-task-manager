# ===================================
# Team Task Manager - Environment Variables
# ===================================
# Copy this file to .env and update values for your environment

# ===== BACKEND DATABASE =====
# MySQL connection details
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ttm?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=jaat12345

# ===== SECURITY =====
# JWT Secret - MUST be at least 256 bits for HMAC-SHA. Generate with: openssl rand -base64 48
# DO NOT commit actual secrets to Git - this is just an example
JWT_SECRET=your-very-long-random-secret-here-at-least-256-bits-change-this-in-production-12345678

# ===== SERVER =====
# Port the backend listens on
PORT=8080

# ===== CORS =====
# Allowed origins for frontend (comma-separated if multiple)
# For development: * (allow all)
# For production: specify frontend URL (e.g., https://yourdomain.com)
CORS_ORIGINS=*

# ===================================
# RAILWAY DEPLOYMENT ONLY
# ===================================
# When deploying to Railway, set these environment variables in the Railway dashboard:
# 1. SPRING_DATASOURCE_URL - Railway MySQL connection string (provided by Railway)
# 2. SPRING_DATASOURCE_USERNAME - Railway MySQL username
# 3. SPRING_DATASOURCE_PASSWORD - Railway MySQL password
# 4. JWT_SECRET - generate a strong secret: openssl rand -base64 48
# 5. CORS_ORIGINS - set to your frontend URL (e.g., https://yourdomain.com)
#
# Railway will automatically set PORT from its environment.
